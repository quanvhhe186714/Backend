PORT=9999
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/?appName=YourApp
JWT_SECRET=change-me-long-random-string
NODE_ENV=production

GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com

# Comma-separated extra CORS origins (optional)
# CORS_ORIGINS=https://your-frontend.vercel.app,https://your-domain.com

# Bank transfer (VietQR)
VIETIN_BANK_ACCOUNT_NAME=
VIETIN_BANK_ACCOUNT=
VIETIN_BANK_BIN=970415

CLOUDINARY_URL=
GEMINI_API_KEY=

# Webhook auto top-up (Casso or Sepay) — set on Render
WEBHOOK_ENABLED=false
WEBHOOK_PROVIDER=sepay
WEBHOOK_SECRET=your-sepay-api-key-for-webhook-auth
